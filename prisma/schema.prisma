generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["daily_ads"]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  brands        Brand[]
  skillRuns     SkillRun[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("da_users")
  @@schema("daily_ads")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("da_accounts")
  @@schema("daily_ads")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("da_sessions")
  @@schema("daily_ads")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("da_verification_tokens")
  @@schema("daily_ads")
}

model Brand {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  url         String
  description String?      @db.Text
  colors      String[]
  voice       String?      @db.Text
  positioning String?      @db.Text
  audience    String?      @db.Text
  usps        String[]
  campaigns   Campaign[]
  adCreatives AdCreative[]
  skillRuns   SkillRun[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("da_brands")
  @@schema("daily_ads")
}

model Campaign {
  id          String       @id @default(cuid())
  brandId     String
  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name        String
  goal        String?
  adCreatives AdCreative[]
  createdAt   DateTime     @default(now())

  @@map("da_campaigns")
  @@schema("daily_ads")
}

model AdCreative {
  id           String    @id @default(cuid())
  brandId      String
  brand        Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  format       String
  hook         String    @db.Text
  body         String    @db.Text
  cta          String?
  angle        String?
  imageUrl     String?
  hookVariants Json?
  feedback     Int?
  createdAt    DateTime  @default(now())

  @@index([brandId])
  @@map("da_ad_creatives")
  @@schema("daily_ads")
}

model SkillRun {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id])
  skill     String
  input     String   @db.Text
  output    String   @db.Text
  createdAt DateTime @default(now())

  @@map("da_skill_runs")
  @@schema("daily_ads")
}
